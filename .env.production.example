# --- Database ---
POSTGRES_USER=stockai
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=stockai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://stockai:change_me_strong_password@postgres:5432/stockai

# --- Auth ---
JWT_SECRET=change_me_use_openssl_rand_hex_32

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Data providers ---
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
ITICK_API_KEY=

# --- Service URLs (docker-compose networking) ---
MARKET_DATA_URL=http://market-data:8001
TECHNICAL_ANALYSIS_URL=http://technical-analysis:8002
ML_PREDICTION_URL=http://ml-prediction:8003
RANKING_ENGINE_URL=http://ranking-engine:8004
SIGNAL_ENGINE_URL=http://signal-engine:8005
STRATEGY_ENGINE_URL=http://strategy-engine:8006
PORTFOLIO_OPTIMIZER_URL=http://portfolio-optimizer:8007
API_GATEWAY_URL=http://api-gateway:8000

# --- Frontend (set to your public domain) ---
NEXT_PUBLIC_API_URL=https://yourdomain.com

# --- Storage ---
PARQUET_DIR=/data/parquet
MODEL_DIR=/data/models

# --- App ---
LOG_LEVEL=INFO
ENV=production

# --- Paper trading (T232-PT1: production runs the paper trading engine; local dev defaults
# to disabled unless explicitly set — see .env.example) ---
ENABLE_PAPER_TRADING=true

# --- Email alerts ---
# EMAIL_PROVIDER=smtp        # or "ses" for AWS SES
# EMAIL_FROM=you@example.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASSWORD=your_app_password
# SES_REGION=us-east-1
