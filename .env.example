# --- Database ---
POSTGRES_USER=stockai
POSTGRES_PASSWORD=stockai_dev
POSTGRES_DB=stockai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://stockai:stockai_dev@postgres:5432/stockai

# --- Auth ---
JWT_SECRET=change_me_use_openssl_rand_hex_32

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Data providers (free tiers) ---
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
ITICK_API_KEY=

# --- Service URLs (docker-compose networking) ---
MARKET_DATA_URL=http://market-data:8001
TECHNICAL_ANALYSIS_URL=http://technical-analysis:8002
ML_PREDICTION_URL=http://ml-prediction:8003
RANKING_ENGINE_URL=http://ranking-engine:8004
SIGNAL_ENGINE_URL=http://signal-engine:8005
STRATEGY_ENGINE_URL=http://strategy-engine:8006
PORTFOLIO_OPTIMIZER_URL=http://portfolio-optimizer:8007
API_GATEWAY_URL=http://api-gateway:8000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Storage ---
PARQUET_DIR=/data/parquet
MODEL_DIR=/data/models

# --- App ---
LOG_LEVEL=INFO
ENV=development

# --- Paper trading (T232-PT1: uncomment to enable the paper trading engine in this env;
# defaults to false/disabled in local dev, which is why local trade history stays empty
# unless this is explicitly set — see the startup log line "paper_trading.enabled" to
# confirm which value a running container actually picked up) ---
# ENABLE_PAPER_TRADING=true

# --- Email alerts (leave EMAIL_PROVIDER blank to disable) ---
# EMAIL_PROVIDER=smtp        # or "ses" for AWS SES
# EMAIL_FROM=you@example.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASSWORD=your_app_password
# SES_REGION=us-east-1
